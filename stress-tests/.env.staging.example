# Copy to .env.staging and fill in. NEVER commit .env.staging.
# Guard script hard-fails if STAGING_PROJECT_REF equals the production ref
# or does not match the Supabase ref pattern ^[a-z0-9]{20}$.

STAGING_PROJECT_REF=
STAGING_DB_URL=
STAGING_API_URL=
STAGING_ANON_KEY=
STAGING_SERVICE_ROLE_KEY=

# Optional: preview URL for Playwright (Phase C)
STAGING_PREVIEW_URL=

# Production ref — hard-coded guard, do not change
PRODUCTION_PROJECT_REF=ncysmppzfjtiekfnomdv

# -----------------------------------------------------------------------------
# Phase-D RLS matrix credentials.
#
# The guarded runner (stress-tests/scripts/run-rls-matrix.sh) requires all
# of the following to be populated with values from your staging project.
#
# UIDs must be real auth.users.id values in staging. They are passed to psql
# via `-v NAME=VALUE` and are never echoed or logged. Emails/passwords are
# used only by @supabase/supabase-js signInWithPassword calls.
#
# NEVER commit .env.staging with real values. Only this .example file, with
# blank right-hand sides, is safe to commit.
# -----------------------------------------------------------------------------
RLS_LOCUM_UID=
RLS_LOCUM_EMAIL=
RLS_LOCUM_PASSWORD=

RLS_RESIDENT_UID=
RLS_RESIDENT_EMAIL=
RLS_RESIDENT_PASSWORD=

RLS_STAFF_UID=
RLS_STAFF_EMAIL=
RLS_STAFF_PASSWORD=

RLS_OPS_UID=
RLS_OPS_EMAIL=
RLS_OPS_PASSWORD=

RLS_OPS_STAFF_UID=
RLS_OPS_STAFF_EMAIL=
RLS_OPS_STAFF_PASSWORD=

RLS_DOCTOR_ADMIN_UID=
RLS_DOCTOR_ADMIN_EMAIL=
RLS_DOCTOR_ADMIN_PASSWORD=

RLS_ADMIN_UID=
RLS_ADMIN_EMAIL=
RLS_ADMIN_PASSWORD=

RLS_SPECIAL_ADMIN_UID=
RLS_SPECIAL_ADMIN_EMAIL=
RLS_SPECIAL_ADMIN_PASSWORD=

RLS_WEBSITE_EDITOR_UID=
RLS_WEBSITE_EDITOR_EMAIL=
RLS_WEBSITE_EDITOR_PASSWORD=

RLS_GUEST_UID=
RLS_GUEST_EMAIL=
RLS_GUEST_PASSWORD=
