# Copy to .env for local development.
# Do not commit your real .env file.
#
# On Lovable Cloud these VITE_SUPABASE_* values are injected automatically
# at build time — you only need to populate this file for local dev outside
# of Lovable. All values below are publishable / client-safe; never put
# service-role keys, Stripe secret keys, or other server secrets here.

VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Optional: only set if running the local MyKad reader bridge for clinic staff.
# Leave blank in production — the app falls back to a safe default.
VITE_MYKAD_BRIDGE_URL=
